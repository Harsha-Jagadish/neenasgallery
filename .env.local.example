# Public site URL — used by metadataBase in app/layout.tsx (OG image absolute URLs etc.).
# Set this to your live domain in Vercel → Project Settings → Environment Variables.
NEXT_PUBLIC_SITE_URL=https://neenasgallery.com

# === Contact form (Resend) ==================================================
# Required for the ContactSheet to actually send emails. Without these, the
# /api/contact route returns 500 and the form shows an error message.

# Secret API key from https://resend.com/api-keys — NEVER commit a real value.
RESEND_API_KEY=

# Sender address. Must live on a domain you've verified in Resend.
# For testing without domain verification, you can use Resend's default test
# sender — but emails sent from that can ONLY be delivered to the email
# address tied to your Resend account.
#   CONTACT_FROM_EMAIL=onboarding@resend.dev          (testing only)
#   CONTACT_FROM_EMAIL=noreply@neenasgallery.com      (production, after verifying neenasgallery.com)
CONTACT_FROM_EMAIL=onboarding@resend.dev

# Destination — defaults to site.email (info@tailoredislandexperiences.com)
# if unset. Override here only if you want a different inbox.
# CONTACT_TO_EMAIL=info@tailoredislandexperiences.com
